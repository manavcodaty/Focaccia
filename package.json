{
  "name": "face-pass",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.33.0"
  },
  "scripts": {
    "db:init": "supabase init --yes",
    "db:functions:env": "node ./scripts/prepare-supabase-functions-env.mjs",
    "db:start": "pnpm run db:functions:env && supabase start",
    "db:functions:serve": "pnpm run db:functions:env && supabase functions serve --no-verify-jwt --env-file supabase/functions/.env.local --import-map supabase/functions/import_map.json",
    "db:reset": "supabase db reset --local --no-seed",
    "db:verify": "bash ./scripts/verify-db-schema.sh",
    "infra:verify": "pnpm run db:verify",
    "postinstall": "node ./scripts/ensure-expo-sqlite-ios-files.mjs"
  }
}
