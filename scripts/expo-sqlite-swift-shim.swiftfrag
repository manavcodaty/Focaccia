  _ destination: OpaquePointer?,
  _ destinationName: UnsafePointer<CChar>?,
  _ source: OpaquePointer?,
  _ sourceName: UnsafePointer<CChar>?
) -> OpaquePointer?

private func exsqlite3_backup_init(
  _ destination: OpaquePointer?,
  _ destinationName: String,
  _ source: OpaquePointer?,
  _ sourceName: String
) -> OpaquePointer? {
  destinationName.withCString { destinationNamePointer in
    sourceName.withCString { sourceNamePointer in
      exsqlite3_backup_init(destination, destinationNamePointer, source, sourceNamePointer)
    }
  }
}

