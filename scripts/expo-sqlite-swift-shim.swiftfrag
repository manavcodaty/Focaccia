  exsqlite3_free(UnsafeMutableRawPointer(pointer))
}

private func exsqlite3_free(_ pointer: UnsafeMutablePointer<UInt8>?) {
  exsqlite3_free(UnsafeMutableRawPointer(pointer))
}

