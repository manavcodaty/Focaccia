// BEGIN FOCACCIA EXPO_SQLITE SHIM
// Xcode 26 can fail to import the vendored Expo SQLite C module into Swift.
// Declare the required symbols explicitly so this module can still compile
// against the vendored `sqlite3.c` build.
private typealias ExSQLiteExecCallback = @convention(c) (
  UnsafeMutableRawPointer?,
  Int32,
  UnsafeMutablePointer<UnsafeMutablePointer<CChar>?>?,
  UnsafeMutablePointer<UnsafeMutablePointer<CChar>?>?
) -> Int32

private typealias ExSQLiteUpdateHook = @convention(c) (
  UnsafeMutableRawPointer?,
  Int32,
  UnsafePointer<CChar>?,
  UnsafePointer<CChar>?,
  sqlite3_int64
) -> Void

private typealias ExSQLiteChangesetFilter = @convention(c) (
  UnsafeMutableRawPointer?,
  UnsafePointer<CChar>?
) -> Int32

private typealias ExSQLiteChangesetConflict = @convention(c) (
  UnsafeMutableRawPointer?,
  Int32,
  OpaquePointer?
) -> Int32

private let SQLITE_CHANGESET_REPLACE: Int32 = 1

private func withOptionalCStringArray<T>(
  _ value: [CChar]?,
  _ body: (UnsafePointer<CChar>?) -> T
) -> T {
  guard let value else {
    return body(nil)
  }
  return value.withUnsafeBufferPointer { buffer in
    body(buffer.baseAddress)
  }
}

private func withOptionalCString<T>(
  _ value: String?,
  _ body: (UnsafePointer<CChar>?) -> T
) -> T {
  guard let value else {
    return body(nil)
  }
  return value.withCString(body)
}

@_silgen_name("exsqlite3_open")
private func exsqlite3_open(
  _ filename: UnsafePointer<CChar>?,
  _ database: UnsafeMutablePointer<OpaquePointer?>?
) -> Int32

private func exsqlite3_open(
  _ filename: String,
  _ database: UnsafeMutablePointer<OpaquePointer?>?
) -> Int32 {
  filename.withCString { exsqlite3_open($0, database) }
}

