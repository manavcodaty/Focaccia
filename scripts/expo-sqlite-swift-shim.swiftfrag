private func exsqlite3_load_extension(
  _ database: OpaquePointer?,
  _ file: [CChar]?,
  _ entryPoint: String?,
  _ error: UnsafeMutablePointer<UnsafeMutablePointer<CChar>?>?
) -> Int32 {
  withOptionalCStringArray(file) { filePointer in
    withOptionalCString(entryPoint) { entryPointPointer in
      exsqlite3_load_extension(database, filePointer, entryPointPointer, error)
    }
  }
}

